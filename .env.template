# 📝 Template de Configuração .env
# Copie este conteúdo e cole no seu arquivo .env

# ==============================================
# BANCO DE DADOS (OBRIGATÓRIO)
# ==============================================

# Escolha UMA destas opções e descomente:

# OPÇÃO 1: Railway (gratuito - https://railway.app)
# DATABASE_URL=postgresql://postgres:sua-senha@roundhouse.proxy.rlwy.net:12345/railway

# OPÇÃO 2: Neon (gratuito - https://neon.tech)
# DATABASE_URL=postgresql://usuario:senha@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require

# OPÇÃO 3: ElephantSQL (gratuito - https://elephantsql.com)
# DATABASE_URL=postgres://usuario:senha@ziggy.db.elephantsql.com/usuario

# OPÇÃO 4: PostgreSQL Local (se instalou no Windows)
# DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/chuteiracansada

# OPÇÃO 5: Docker (se instalar)
# DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/chuteiracansada


# ==============================================
# AUTENTICAÇÃO (OBRIGATÓRIO)
# ==============================================

# Login do administrador (configure o seu)
ADMIN_EMAIL=admin@admin
ADMIN_PASSWORD=<DEFINA_UMA_SENHA_FORTE>

# Secrets (gere valores longos e aleatórios)
ADMIN_JWT_SECRET=<GERE_UM_SEGREDO_LONGO_E_ALEATORIO>
SESSION_SECRET=<GERE_OUTRO_SEGREDO_LONGO_E_ALEATORIO>


# ==============================================
# SERVIDOR
# ==============================================

NODE_ENV=development
PORT=3000

# (Opcional) Em desenvolvimento, se a porta estiver ocupada, o app tenta automaticamente
# 3001, 3002... para evitar falhas intermitentes (EADDRINUSE).
# Se você quiser travar a porta exatamente em PORT mesmo no dev, use:
# PORT_PINNED=true


# ==============================================
# GOOGLE OAUTH (OPCIONAL)
# ==============================================
# Descomente e configure se quiser usar login com Google
# Consulte GOOGLE_OAUTH.md para instruções completas

# GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=seu-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/oauth/google/callback


# ==============================================
# INSTRUÇÕES RÁPIDAS
# ==============================================
#
# 1. Escolha UM provedor de banco acima e descomente a linha DATABASE_URL
# 2. Gere secrets aleatórios longos (recomendado 64+ caracteres)
# 3. Para gerar um secret aleatório no PowerShell:
#    -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 64 | ForEach-Object {[char]$_})
# 4. Salve este arquivo como ".env" na raiz do projeto
#
# Depois disso:
# node server/test-system.js       (verificar se está tudo OK)
# node server/seed-database.js     (popular com dados de teste)
# npm start                         (iniciar o servidor)
#
# Acesse: http://localhost:3000/login.html
# Login admin: admin@admin / admin123
# Login associado: carlos.silva@gmail.com / 123456
